# Copy to .env and edit. Do NOT commit .env.

# Signing key for login tokens. Generate one: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Where the SQLite file lives.
DATABASE_URL=sqlite:///./soroban.db

# Login stays valid this many days (3 个月).
TOKEN_EXPIRE_DAYS=90

# ---- 以下都有默认值，按需才填（config.py 里可覆盖）----
# 允许跨域的前端来源（仅前后端分开跑时才用到；同源托管/Vite 代理下用不上）。
# 局域网从别的设备访问、且前端单独跑时，加上本机 IP：
# CORS_ORIGINS=["http://localhost:5173","http://192.168.1.10:5173"]
# 爬虫插件目录（默认 = 仓库下 scraper/）：
# SCRAPER_DIR=/absolute/path/to/scraper
# 汇率源参数（默认 CNY→JPY、每 6h 刷新）：
# FX_BASE=CNY
# FX_QUOTE=JPY
# FX_REFRESH=21600
